@page
@model MyRazor.Pages.Courses.CreateModel

@{
    ViewData["Title"] = "Create Course";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(79, 70, 229, .08), transparent 30%),
            linear-gradient(180deg, #f7f9fd 0%, #f2f5fa 100%);
        color: #1f2937;
    }

    .create-page {
        min-height: calc(100vh - 70px);
        padding: 46px 0;
    }

    .page-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #eef2ff;
        color: #4f46e5;
        border-radius: 999px;
        padding: 8px 15px;
        font-size: 13px;
        font-weight: 800;
        margin-bottom: 14px;
    }

    .page-title {
        font-size: 34px;
        font-weight: 900;
        color: #111827;
        letter-spacing: -.8px;
        margin-bottom: 6px;
    }

    .page-subtitle {
        color: #64748b;
        font-size: 16px;
        margin-bottom: 0;
    }

    .create-card {
        background: rgba(255, 255, 255, .94);
        border: 1px solid #e8edf5;
        border-radius: 30px;
        box-shadow: 0 20px 50px rgba(15, 23, 42, .07);
        overflow: hidden;
        backdrop-filter: blur(12px);
    }

    .form-side {
        padding: 36px;
    }

    .preview-side {
        height: 100%;
        padding: 36px;
        background:
            radial-gradient(circle at top right, rgba(79, 70, 229, .16), transparent 36%),
            linear-gradient(135deg, #eef3fb, #f8fafc);
        border-left: 1px solid #e8edf5;
    }

    .form-label {
        font-size: 14px;
        font-weight: 800;
        color: #334155;
        margin-bottom: 8px;
    }

    .form-control,
    .form-select {
        border: 1px solid #dfe6f0;
        border-radius: 16px;
        padding: 13px 15px;
        background: #fff;
        color: #111827;
        transition: .2s ease;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #818cf8;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, .12);
    }

    textarea.form-control {
        resize: none;
    }

    .field-box {
        display: flex;
        gap: 14px;
        align-items: flex-start;
    }

    .field-icon {
        width: 44px;
        height: 44px;
        border-radius: 15px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 18px;
    }

    .field-content {
        flex: 1;
    }

    .select-help {
        font-size: 13px;
        color: #94a3b8;
        margin-top: 8px;
    }

    .level-preview {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 10px;
    }

    .level-chip {
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
    }

    .level-chip.beginner {
        background: #dbeafe;
        color: #2563eb;
    }

    .level-chip.intermediate {
        background: #fff7db;
        color: #c06a00;
    }

    .level-chip.advanced {
        background: #fee2e2;
        color: #dc2626;
    }

    .btn-soft {
        height: 46px;
        border-radius: 15px;
        padding: 0 18px;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-submit {
        height: 46px;
        border: none;
        border-radius: 15px;
        padding: 0 22px;
        background: linear-gradient(135deg, #4f46e5, #6d5dfc);
        color: #fff;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        gap: 9px;
        box-shadow: 0 16px 30px rgba(79, 70, 229, .24);
        transition: .2s ease;
    }

    .btn-submit:hover {
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 22px 38px rgba(79, 70, 229, .30);
    }

    .preview-card {
        background: #fff;
        border: 1px solid #e8edf5;
        border-radius: 26px;
        padding: 26px;
        box-shadow: 0 18px 35px rgba(15, 23, 42, .06);
    }

    .preview-icon {
        width: 66px;
        height: 66px;
        border-radius: 22px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        box-shadow: 0 18px 30px rgba(79, 70, 229, .24);
        margin-bottom: 22px;
    }

    .preview-title {
        font-size: 23px;
        font-weight: 900;
        color: #111827;
        margin-bottom: 8px;
    }

    .preview-text {
        color: #64748b;
        font-size: 14px;
        line-height: 1.7;
        margin-bottom: 22px;
    }

    .mini-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 13px 0;
        border-bottom: 1px solid #edf2f7;
        font-size: 14px;
    }

    .mini-row:last-child {
        border-bottom: none;
    }

    .mini-row span {
        color: #64748b;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .mini-row strong {
        color: #111827;
        font-weight: 900;
    }

    .tip-box {
        margin-top: 22px;
        border-radius: 22px;
        padding: 18px;
        background: rgba(79, 70, 229, .07);
        border: 1px solid rgba(79, 70, 229, .12);
        color: #475569;
        font-size: 14px;
        line-height: 1.6;
    }

    .validation-summary-errors {
        background: #fee2e2;
        color: #b91c1c;
        border: 1px solid #fecaca;
        border-radius: 16px;
        padding: 14px 18px;
        margin-bottom: 20px;
    }

    @@media (max-width: 991px) {
        .form-side,
        .preview-side {
            padding: 24px;
        }

        .preview-side {
            border-left: none;
            border-top: 1px solid #e8edf5;
        }

        .page-title {
            font-size: 28px;
        }
    }
</style>

<div class="create-page">

    <div class="container">

        <div class="d-flex justify-content-between align-items-start gap-3 mb-4">

            <div>
                <div class="page-label">
                    <i class="bi bi-mortarboard-fill"></i>
                    Course Builder
                </div>

                <h1 class="page-title">
                    Create New Course
                </h1>

                <p class="page-subtitle">
                    Add a new course to your LMS catalog.
                </p>
            </div>

            <a asp-page="./Index"
               class="btn btn-light border btn-soft shadow-sm">
                <i class="bi bi-arrow-left"></i>
                Back
            </a>

        </div>

        <div class="create-card">

            <div class="row g-0">

                <div class="col-lg-8">

                    <div class="form-side">

                        <form method="post">

                            <div asp-validation-summary="ModelOnly"></div>

                            <div class="mb-4 field-box">

                                <div class="field-icon">
                                    <i class="bi bi-type"></i>
                                </div>

                                <div class="field-content">
                                    <label asp-for="Dto.Title" class="form-label">
                                        Course Title
                                    </label>

                                    <input asp-for="Dto.Title"
                                           class="form-control"
                                           placeholder="ASP.NET Core Web API Masterclass" />

                                    <span asp-validation-for="Dto.Title"
                                          class="text-danger small"></span>
                                </div>

                            </div>

                            <div class="mb-4 field-box">

                                <div class="field-icon">
                                    <i class="bi bi-card-text"></i>
                                </div>

                                <div class="field-content">
                                    <label asp-for="Dto.Description" class="form-label">
                                        Description
                                    </label>

                                    <textarea asp-for="Dto.Description"
                                              class="form-control"
                                              rows="5"
                                              placeholder="Write a short course description..."></textarea>

                                    <span asp-validation-for="Dto.Description"
                                          class="text-danger small"></span>
                                </div>

                            </div>

                            <div class="row g-4">

                                <div class="col-md-6">

                                    <div class="field-box">

                                        <div class="field-icon">
                                            <i class="bi bi-cash-stack"></i>
                                        </div>

                                        <div class="field-content">
                                            <label asp-for="Dto.Price" class="form-label">
                                                Price
                                            </label>

                                            <input asp-for="Dto.Price"
                                                   class="form-control"
                                                   type="number"
                                                   step="0.01"
                                                   min="0"
                                                   placeholder="0.00" />

                                            <span asp-validation-for="Dto.Price"
                                                  class="text-danger small"></span>
                                        </div>

                                    </div>

                                </div>

                                <div class="col-md-6">

                                    <div class="field-box">

                                        <div class="field-icon">
                                            <i class="bi bi-bar-chart-fill"></i>
                                        </div>

                                        <div class="field-content">
                                            <label asp-for="Dto.Level" class="form-label">
                                                Level
                                            </label>

                                            <select asp-for="Dto.Level"
                                                    class="form-select">
                                                <option value="Beginner">Beginner</option>
                                                <option value="Intermediate">Intermediate</option>
                                                <option value="Advanced">Advanced</option>
                                            </select>

                                          

                                            <span asp-validation-for="Dto.Level"
                                                  class="text-danger small"></span>
                                        </div>

                                    </div>

                                </div>

                            </div>

                            <div class="mt-4 field-box">

                                <div class="field-icon">
                                    <i class="bi bi-tags-fill"></i>
                                </div>

                                <div class="field-content">
                                    <label asp-for="Dto.CategoryId" class="form-label">
                                        Category
                                    </label>

                                    <select asp-for="Dto.CategoryId"
                                            asp-items="Model.Categories"
                                            class="form-select">
                                        <option value="">Select category</option>
                                    </select>

                                    <div class="select-help">
                                        CategoryId бояд Guid-и ҳақиқӣ аз database бошад.
                                    </div>

                                    <span asp-validation-for="Dto.CategoryId"
                                          class="text-danger small"></span>
                                </div>

                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-5">

                                <a asp-page="./Index"
                                   class="btn btn-light border btn-soft">
                                    Cancel
                                </a>

                                <button type="submit" class="btn-submit">
                                    <i class="bi bi-plus-circle-fill"></i>
                                    Create Course
                                </button>

                            </div>

                        </form>

                    </div>

                </div>

                <div class="col-lg-4">

                    <div class="preview-side">

                        <div class="preview-card">

                            <div class="preview-icon">
                                <i class="bi bi-journal-code"></i>
                            </div>

                            <div class="preview-title">
                                Course Preview
                            </div>

                            <p class="preview-text">
                                After creating this course, you can add lessons, publish it,
                                enroll students and collect reviews.
                            </p>

                            <div class="mini-row">
                                <span>
                                    <i class="bi bi-patch-check-fill"></i>
                                    Status
                                </span>
                                <strong>Draft</strong>
                            </div>

                            <div class="mini-row">
                                <span>
                                    <i class="bi bi-collection-play-fill"></i>
                                    Lessons
                                </span>
                                <strong>0</strong>
                            </div>

                            <div class="mini-row">
                                <span>
                                    <i class="bi bi-people-fill"></i>
                                    Students
                                </span>
                                <strong>0</strong>
                            </div>

                            <div class="mini-row">
                                <span>
                                    <i class="bi bi-star-fill"></i>
                                    Rating
                                </span>
                                <strong>0.0</strong>
                            </div>

                        </div>

                        <div class="tip-box">
                            <strong>Tip:</strong>
                            Keep the title short, choose the correct category,
                            and publish the course only after adding lessons.
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
