@page
@model MyRazor.Pages.Courses.IndexModel

@{
    Layout = null;
    ViewData["Title"] = "Courses";

    var courses = Model.Courses ?? new();
    var totalCourses = courses.Count;
    var publishedCourses = courses.Count(x => x.IsPublished);
    var draftCourses = courses.Count(x => !x.IsPublished);
    var totalStudents = courses.Sum(x => x.StudentsCount);
    var totalLessons = courses.Sum(x => x.LessonsCount);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - MyRazor</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --page-bg: #f6f8fb;
            --sidebar-bg: #edf2f7;
            --surface: #ffffff;
            --surface-soft: #f8fafc;
            --text: #111827;
            --slate: #334155;
            --muted: #64748b;
            --faint: #94a3b8;
            --border: #e8edf5;
            --indigo: #4f46e5;
            --indigo-soft: #eef2ff;
            --green: #059669;
            --green-soft: #dcfce7;
            --amber: #b45309;
            --amber-soft: #fef3c7;
            --red: #dc2626;
            --red-soft: #fee2e2;
            --blue-soft: #dbeafe;
            --shadow: 0 16px 38px rgba(15, 23, 42, .06);
            --shadow-soft: 0 8px 22px rgba(15, 23, 42, .045);
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            min-height: 100%;
            margin: 0;
        }

        body {
            background: var(--page-bg);
            color: var(--text);
            font-family: "Inter", "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
            overflow-x: hidden;
        }

        .dashboard-shell {
            min-height: 100vh;
            background:
                radial-gradient(circle at 78% 4%, rgba(79, 70, 229, .07), transparent 28%),
                linear-gradient(180deg, #f8fafc 0%, var(--page-bg) 100%);
        }

        .sidebar {
            position: fixed;
            inset: 0 auto 0 0;
            width: 264px;
            min-height: 100vh;
            padding: 22px 16px;
            background: var(--sidebar-bg);
            border-right: 1px solid rgba(226, 232, 240, .9);
            display: flex;
            flex-direction: column;
            z-index: 20;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 4px 10px 24px;
        }

        .brand-mark {
            width: 42px;
            height: 42px;
            border-radius: 16px;
            background: #334155;
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 12px 24px rgba(51, 65, 85, .16);
        }

        .brand-title {
            margin: 0;
            color: #1f2937;
            font-size: 21px;
            font-weight: 800;
            letter-spacing: -.04em;
            line-height: 1;
        }

        .brand-caption {
            margin-top: 4px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
        }

        .nav-label {
            margin: 12px 12px 10px;
            color: var(--faint);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .12em;
            text-transform: uppercase;
        }

        .side-nav {
            display: grid;
            gap: 6px;
        }

        .side-link {
            min-height: 46px;
            padding: 0 13px;
            border-radius: 15px;
            color: #475569;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            transition: background .18s ease, color .18s ease, box-shadow .18s ease;
        }

        .side-link i {
            width: 19px;
            color: #64748b;
            font-size: 16px;
        }

        .side-link:hover,
        .side-link.active {
            background: #ffffff;
            color: var(--indigo);
            box-shadow: var(--shadow-soft);
        }

        .side-link:hover i,
        .side-link.active i {
            color: var(--indigo);
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 16px;
            border: 1px solid rgba(226, 232, 240, .85);
            border-radius: 20px;
            background: rgba(255, 255, 255, .58);
        }

        .sidebar-footer strong {
            color: #1f2937;
            display: block;
            font-size: 13px;
            margin-bottom: 5px;
        }

        .sidebar-footer span {
            color: var(--muted);
            display: block;
            font-size: 12px;
            line-height: 1.5;
        }

        .main {
            min-height: 100vh;
            margin-left: 264px;
            padding: 22px 24px 32px;
        }

        .topbar {
            min-height: 48px;
            margin-bottom: 22px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
        }

        .page-heading h1 {
            margin: 0;
            color: #111827;
            font-size: 25px;
            font-weight: 800;
            letter-spacing: -.035em;
        }

        .page-heading p {
            margin: 5px 0 0;
            color: var(--muted);
            font-size: 13px;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .top-pill,
        .top-icon,
        .profile-pill {
            height: 42px;
            border: 1px solid var(--border);
            border-radius: 14px;
            background: rgba(255, 255, 255, .9);
            box-shadow: var(--shadow-soft);
            color: var(--slate);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
        }

        .top-pill {
            padding: 0 13px;
            gap: 8px;
            font-size: 13px;
            font-weight: 700;
        }

        .top-icon {
            width: 42px;
            color: #475569;
        }

        .wallet-pill {
            height: 42px;
            padding: 0 14px;
            border-radius: 14px;
            border: 1px solid #e0e7ff;
            background: var(--indigo-soft);
            color: var(--indigo);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 800;
        }

        .profile-pill {
            padding: 0 12px 0 6px;
            gap: 8px;
            font-size: 13px;
            font-weight: 700;
        }

        .profile-initial {
            width: 30px;
            height: 30px;
            border-radius: 11px;
            background: #334155;
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 800;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 18px;
            margin-bottom: 24px;
        }

        .stat-card {
            min-height: 150px;
            padding: 22px;
            border: 1px solid var(--border);
            border-radius: 24px;
            background: rgba(255, 255, 255, .92);
            box-shadow: var(--shadow-soft);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform .18s ease, box-shadow .18s ease;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow);
        }

        .stat-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
        }

        .stat-label {
            margin: 0;
            color: var(--muted);
            font-size: 13px;
            font-weight: 700;
        }

        .stat-title {
            margin: 7px 0 0;
            color: #1f2937;
            font-size: 16px;
            font-weight: 800;
            letter-spacing: -.02em;
        }

        .stat-icon {
            width: 42px;
            height: 42px;
            border-radius: 15px;
            background: var(--indigo-soft);
            color: var(--indigo);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
        }

        .stat-icon.green {
            background: var(--green-soft);
            color: var(--green);
        }

        .stat-icon.amber {
            background: var(--amber-soft);
            color: var(--amber);
        }

        .stat-icon.slate {
            background: #f1f5f9;
            color: #475569;
        }

        .stat-value {
            margin-top: 22px;
            color: #111827;
            font-size: 30px;
            font-weight: 800;
            letter-spacing: -.04em;
            line-height: 1;
        }

        .stat-meta {
            margin-top: 8px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
        }

        .table-card {
            overflow: visible;
            border: 1px solid var(--border);
            border-radius: 24px;
            background: rgba(255, 255, 255, .96);
            box-shadow: 0 20px 48px rgba(15, 23, 42, .075);
        }

        .table-toolbar {
            min-height: 76px;
            padding: 18px 20px;
            border-bottom: 1px solid var(--border);
            border-radius: 24px 24px 0 0;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, .98), rgba(248, 250, 252, .9));
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
        }

        .table-toolbar h2 {
            margin: 0;
            color: #111827;
            font-size: 19px;
            font-weight: 800;
            letter-spacing: -.025em;
        }

        .table-toolbar p {
            margin: 4px 0 0;
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
        }

        .btn-create {
            height: 40px;
            padding: 0 15px;
            border: 0;
            border-radius: 14px;
            background: var(--indigo);
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 800;
            text-decoration: none;
            box-shadow: 0 12px 22px rgba(79, 70, 229, .22);
            transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
            white-space: nowrap;
        }

        .btn-create:hover {
            background: #4338ca;
            color: #ffffff;
            transform: translateY(-1px);
            box-shadow: 0 16px 28px rgba(79, 70, 229, .27);
        }

        .table-responsive {
            overflow-x: visible;
            border-radius: 0 0 24px 24px;
        }

        .courses-table {
            width: 100%;
            min-width: 0;
            margin: 0;
            table-layout: fixed;
        }

        .courses-table col.course-col {
            width: 30%;
        }

        .courses-table col.instructor-col {
            width: 13%;
        }

        .courses-table col.price-col {
            width: 8%;
        }

        .courses-table col.level-col {
            width: 11%;
        }

        .courses-table col.students-col {
            width: 9%;
        }

        .courses-table col.category-col {
            width: 11%;
        }

        .courses-table col.status-col {
            width: 11%;
        }

        .courses-table col.actions-col {
            width: 7%;
        }

        .courses-table thead th {
            padding: 13px 12px;
            border: 0;
            background: #edf2f8;
            color: #475569;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .08em;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .courses-table tbody td {
            padding: 14px 12px;
            border-top: 1px solid #edf1f6;
            color: var(--text);
            font-size: 13px;
            vertical-align: middle;
        }

        .courses-table tbody tr {
            transition: background .16s ease;
        }

        .courses-table tbody tr:hover {
            background: #fbfdff;
        }

        .course-cell {
            display: flex;
            align-items: center;
            gap: 11px;
            min-width: 0;
        }

        .course-thumb,
        .course-avatar {
            width: 44px;
            height: 44px;
            border-radius: 15px;
            flex: 0 0 auto;
            object-fit: cover;
            box-shadow: 0 8px 18px rgba(15, 23, 42, .08);
        }

        .course-avatar {
            background: linear-gradient(135deg, #475569, #334155);
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 800;
        }

        .course-info {
            min-width: 0;
        }

        .course-title {
            color: #111827;
            font-size: 13px;
            font-weight: 800;
            line-height: 1.25;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .course-description {
            max-width: 100%;
            margin-top: 4px;
            color: var(--muted);
            font-size: 11px;
            line-height: 1.35;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .instructor-name {
            color: #334155;
            font-size: 12px;
            font-weight: 700;
            line-height: 1.35;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .price-text {
            color: #111827;
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .level-badge,
        .status-badge,
        .students-count {
            min-height: 28px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            padding: 0 9px;
            font-size: 11px;
            font-weight: 800;
            white-space: nowrap;
        }

        .level-badge.beginner {
            background: var(--blue-soft);
            color: #2563eb;
        }

        .level-badge.intermediate {
            background: var(--amber-soft);
            color: var(--amber);
        }

        .level-badge.advanced {
            background: var(--red-soft);
            color: var(--red);
        }

        .students-count {
            background: #f1f5f9;
            color: #334155;
        }

        .students-count i {
            color: var(--indigo);
            font-size: 13px;
        }

        .category-text {
            color: #475569;
            font-size: 12px;
            font-weight: 700;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .status-badge.published {
            background: var(--green-soft);
            color: var(--green);
        }

        .status-badge.draft {
            background: #f1f5f9;
            color: var(--muted);
        }

        .action-menu-btn {
            width: 34px;
            height: 34px;
            border: 1px solid var(--border);
            border-radius: 13px;
            background: #ffffff;
            color: #475569;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: background .16s ease, color .16s ease, box-shadow .16s ease;
        }

        .action-menu-btn:hover,
        .action-menu-btn.show {
            background: var(--indigo-soft);
            color: var(--indigo);
            box-shadow: var(--shadow-soft);
        }

        .premium-dropdown {
            min-width: 184px;
            padding: 8px;
            border: 1px solid var(--border);
            border-radius: 16px;
            box-shadow: 0 18px 38px rgba(15, 23, 42, .12);
        }

        .premium-dropdown .dropdown-item {
            min-height: 38px;
            border-radius: 11px;
            color: #334155;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            font-weight: 700;
        }

        .premium-dropdown .dropdown-item:hover {
            background: #f8fafc;
        }

        .premium-dropdown .dropdown-item i {
            width: 18px;
            font-size: 15px;
        }

        .premium-dropdown .details i {
            color: var(--indigo);
        }

        .premium-dropdown .edit i {
            color: var(--amber);
        }

        .premium-dropdown .delete {
            color: #991b1b;
        }

        .premium-dropdown .delete i {
            color: var(--red);
        }

        .empty-state {
            padding: 58px 20px;
            text-align: center;
            color: var(--muted);
        }

        .empty-state i {
            margin-bottom: 12px;
            color: #cbd5e1;
            font-size: 40px;
            display: block;
        }

        @@media (max-width: 1180px) {
            .sidebar {
                width: 244px;
            }

            .main {
                margin-left: 244px;
                padding: 20px;
            }

            .stats-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .table-responsive {
                overflow-x: auto;
            }

            .courses-table {
                min-width: 980px;
            }
        }

        @@media (max-width: 860px) {
            .sidebar {
                position: static;
                width: 100%;
                min-height: auto;
            }

            .main {
                margin-left: 0;
                padding: 18px;
            }

            .topbar,
            .table-toolbar {
                align-items: flex-start;
                flex-direction: column;
            }

            .topbar-actions {
                justify-content: flex-start;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
<div class="dashboard-shell">
    <aside class="sidebar">
        <div class="brand">
            <div class="brand-mark">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div>
                <h1 class="brand-title">Omuz</h1>
                <div class="brand-caption">Online courses CRM</div>
            </div>
        </div>

        <div class="nav-label">Workspace</div>
        <nav class="side-nav">
            <a asp-page="./Index" class="side-link active">
                <i class="bi bi-grid-1x2-fill"></i>
                Courses
            </a>
            <a asp-page="/Lessons/Index" class="side-link">
                <i class="bi bi-play-btn-fill"></i>
                Lessons
            </a>
            <a asp-page="/Categories/Index" class="side-link">
                <i class="bi bi-tags-fill"></i>
                Categories
            </a>
            <a asp-page="/Enrollments/Index" class="side-link">
                <i class="bi bi-people-fill"></i>
                Students
            </a>
            <a asp-page="/Privacy" class="side-link">
                <i class="bi bi-shield-check"></i>
                Settings
            </a>
        </nav>

        <div class="sidebar-footer">
            <strong>.NET April 2026</strong>
            <span>Premium LMS dashboard for managing course content and student activity.</span>
        </div>
    </aside>

    <main class="main">
        <header class="topbar">
            <div class="page-heading">
                <h1>Courses Dashboard</h1>
                <p>Manage courses, instructors, publishing status and students from one clean workspace.</p>
            </div>

            <div class="topbar-actions">
                <div class="top-pill">
                    <i class="bi bi-globe2"></i>
                    ENG
                    <i class="bi bi-chevron-down"></i>
                </div>
                <a href="#" class="top-icon" aria-label="Notifications">
                    <i class="bi bi-bell"></i>
                </a>
                <a href="#" class="top-icon" aria-label="Theme">
                    <i class="bi bi-moon"></i>
                </a>
                <div class="wallet-pill">
                    <i class="bi bi-wallet2"></i>
                    $0.00
                </div>
                <div class="profile-pill">
                    <span class="profile-initial">AK</span>
                    Admin
                </div>
            </div>
        </header>

        <section class="stats-grid" aria-label="Course statistics">
            <article class="stat-card">
                <div class="stat-top">
                    <div>
                        <p class="stat-label">Catalog</p>
                        <h2 class="stat-title">Total courses</h2>
                    </div>
                    <div class="stat-icon">
                        <i class="bi bi-journal-bookmark-fill"></i>
                    </div>
                </div>
                <div>
                    <div class="stat-value">@totalCourses</div>
                    <div class="stat-meta">@totalLessons lessons in catalog</div>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-top">
                    <div>
                        <p class="stat-label">Live content</p>
                        <h2 class="stat-title">Published</h2>
                    </div>
                    <div class="stat-icon green">
                        <i class="bi bi-check2-circle"></i>
                    </div>
                </div>
                <div>
                    <div class="stat-value">@publishedCourses</div>
                    <div class="stat-meta">Available for students</div>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-top">
                    <div>
                        <p class="stat-label">Enrollment</p>
                        <h2 class="stat-title">Students</h2>
                    </div>
                    <div class="stat-icon slate">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
                <div>
                    <div class="stat-value">@totalStudents</div>
                    <div class="stat-meta">Across all courses</div>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-top">
                    <div>
                        <p class="stat-label">Draft queue</p>
                        <h2 class="stat-title">Drafts</h2>
                    </div>
                    <div class="stat-icon amber">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                </div>
                <div>
                    <div class="stat-value">@draftCourses</div>
                    <div class="stat-meta">Need review before publishing</div>
                </div>
            </article>
        </section>

        <section class="table-card">
            <div class="table-toolbar">
                <div>
                    <h2>Courses List</h2>
                    <p>@totalCourses courses / @publishedCourses published / @totalStudents students</p>
                </div>

                <a asp-page="./Create" class="btn-create">
                    <i class="bi bi-plus-circle"></i>
                    Add Course
                </a>
            </div>

            <div class="table-responsive">
                <table class="table courses-table align-middle">
                    <colgroup>
                        <col class="course-col" />
                        <col class="instructor-col" />
                        <col class="price-col" />
                        <col class="level-col" />
                        <col class="students-col" />
                        <col class="category-col" />
                        <col class="status-col" />
                        <col class="actions-col" />
                    </colgroup>

                    <thead>
                    <tr>
                        <th>Course</th>
                        <th>Instructor</th>
                        <th>Price</th>
                        <th>Level</th>
                        <th>Students</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>

                    <tbody>
                    @if (courses.Any())
                    {
                        foreach (var courseItem in courses)
                        {
                            var instructorName = string.IsNullOrWhiteSpace(courseItem.InstructorName)
                                ? "Instructor"
                                : courseItem.InstructorName;

                            var categoryName = string.IsNullOrWhiteSpace(courseItem.CategoryName)
                                ? "No Category"
                                : courseItem.CategoryName;

                            var firstLetter = string.IsNullOrWhiteSpace(courseItem.Title)
                                ? "C"
                                : courseItem.Title.Substring(0, 1).ToUpper();

                            var levelClass = courseItem.Level.ToString().ToLowerInvariant();

                            <tr>
                                <td>
                                    <div class="course-cell">
                                        @if (!string.IsNullOrWhiteSpace(courseItem.ThumbnailUrl))
                                        {
                                            <img src="@courseItem.ThumbnailUrl" class="course-thumb" alt="@courseItem.Title" />
                                        }
                                        else
                                        {
                                            <div class="course-avatar">@firstLetter</div>
                                        }

                                        <div class="course-info">
                                            <div class="course-title">@courseItem.Title</div>
                                            <div class="course-description">
                                                @(string.IsNullOrWhiteSpace(courseItem.Description)
                                                    ? "No description available."
                                                    : courseItem.Description)
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <div class="instructor-name">@instructorName</div>
                                </td>

                                <td>
                                    <div class="price-text">$@courseItem.Price.ToString("0.00")</div>
                                </td>

                                <td>
                                    <span class="level-badge @levelClass">@courseItem.Level</span>
                                </td>

                                <td>
                                    <span class="students-count">
                                        <i class="bi bi-people-fill"></i>
                                        @courseItem.StudentsCount
                                    </span>
                                </td>

                                <td>
                                    <div class="category-text">@categoryName</div>
                                </td>

                                <td>
                                    @if (courseItem.IsPublished)
                                    {
                                        <span class="status-badge published">Published</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge draft">Draft</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="dropdown">
                                        <button class="action-menu-btn"
                                                type="button"
                                                data-bs-toggle="dropdown"
                                                aria-expanded="false"
                                                aria-label="Course actions">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>

                                        <ul class="dropdown-menu dropdown-menu-end premium-dropdown">
                                            <li>
                                                <a asp-page="./Details" asp-route-id="@courseItem.Id" class="dropdown-item details">
                                                    <i class="bi bi-eye"></i>
                                                    View Details
                                                </a>
                                            </li>
                                            <li>
                                                <a asp-page="./Edit" asp-route-id="@courseItem.Id" class="dropdown-item edit">
                                                    <i class="bi bi-pencil-square"></i>
                                                    Edit Course
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider my-2" /></li>
                                            <li>
                                                <a asp-page="./Delete" asp-route-id="@courseItem.Id" class="dropdown-item delete">
                                                    <i class="bi bi-trash3"></i>
                                                    Delete Course
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8">
                                <div class="empty-state">
                                    <i class="bi bi-folder-x"></i>
                                    <div class="fw-bold">No courses found</div>
                                    <div>Add your first course to start managing the platform.</div>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
