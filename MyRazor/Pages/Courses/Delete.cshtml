@page "{id:guid}"
@model MyRazor.Pages.Courses.Delete

@{
    ViewData["Title"] = "Delete Course";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(220, 38, 38, .08), transparent 30%),
            linear-gradient(180deg, #f7f9fd 0%, #f2f5fa 100%);
        color: #1f2937;
    }

    .delete-page {
        min-height: calc(100vh - 70px);
        padding: 54px 0;
    }

    .delete-card {
        max-width: 760px;
        margin: 0 auto;
        background: rgba(255, 255, 255, .96);
        border: 1px solid #e8edf5;
        border-radius: 30px;
        box-shadow: 0 20px 50px rgba(15, 23, 42, .08);
        overflow: hidden;
    }

    .delete-header {
        padding: 34px 34px 22px;
        border-bottom: 1px solid #edf2f7;
    }

    .delete-icon {
        width: 64px;
        height: 64px;
        border-radius: 22px;
        background: #fee2e2;
        color: #dc2626;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        margin-bottom: 18px;
    }

    .delete-title {
        margin: 0;
        color: #111827;
        font-size: 30px;
        font-weight: 900;
        letter-spacing: -.7px;
    }

    .delete-subtitle {
        margin: 8px 0 0;
        color: #64748b;
        font-size: 15px;
        line-height: 1.7;
    }

    .course-box {
        margin: 26px 34px;
        padding: 22px;
        border: 1px solid #e8edf5;
        border-radius: 22px;
        background: #f8fafc;
    }

    .course-name {
        color: #111827;
        font-size: 20px;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .course-meta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .meta-pill {
        min-height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        background: #ffffff;
        border: 1px solid #e8edf5;
        color: #475569;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        font-weight: 800;
    }

    .warning-box {
        margin: 0 34px 28px;
        padding: 16px 18px;
        border-radius: 18px;
        background: #fff7ed;
        border: 1px solid #fed7aa;
        color: #9a3412;
        font-weight: 700;
        line-height: 1.6;
    }

    .delete-actions {
        padding: 0 34px 34px;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .btn-soft,
    .btn-delete {
        height: 46px;
        border-radius: 15px;
        padding: 0 20px;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-delete {
        border: none;
        background: #dc2626;
        color: #fff;
        box-shadow: 0 16px 30px rgba(220, 38, 38, .22);
    }

    .btn-delete:hover {
        color: #fff;
        background: #b91c1c;
    }
</style>

<div class="delete-page">
    <div class="container">
        <div class="delete-card">

            <div class="delete-header">
                <div class="delete-icon">
                    <i class="bi bi-trash3-fill"></i>
                </div>
                <h1 class="delete-title">Delete Course</h1>
                <p class="delete-subtitle">
                    Are you sure you want to delete this course? This action cannot be undone.
                </p>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mx-4 mt-3"></div>

            <div class="course-box">
                <div class="course-name">@Model.Course.Title</div>
                <div class="text-secondary">
                    @(string.IsNullOrWhiteSpace(Model.Course.Description)
                        ? "No description available."
                        : Model.Course.Description)
                </div>

                <div class="course-meta">
                    <span class="meta-pill">
                        <i class="bi bi-cash-stack"></i>
                        $@Model.Course.Price.ToString("0.00")
                    </span>
                    <span class="meta-pill">
                        <i class="bi bi-bar-chart-fill"></i>
                        @Model.Course.Level
                    </span>
                    <span class="meta-pill">
                        <i class="bi bi-tag-fill"></i>
                        @(string.IsNullOrWhiteSpace(Model.Course.CategoryName)
                            ? "No Category"
                            : Model.Course.CategoryName)
                    </span>
                    <span class="meta-pill">
                        <i class="bi bi-people-fill"></i>
                        @Model.Course.StudentsCount students
                    </span>
                </div>
            </div>

            <div class="warning-box">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Deleting this course will permanently remove it from the course list.
            </div>

            <form method="post" asp-route-id="@Model.Course.Id" class="delete-actions">
                @Html.AntiForgeryToken()

                <a asp-page="./Index" class="btn btn-light border btn-soft">
                    <i class="bi bi-x-lg"></i>
                    Cancel
                </a>

                <button type="submit" class="btn-delete">
                    <i class="bi bi-trash3"></i>
                    Delete Course
                </button>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}