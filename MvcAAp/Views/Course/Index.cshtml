@using Domain.Enums
@model MvcAAp.Models.CoursePagedViewModel

@{
    Layout = null;
    ViewData["Title"] = "Courses";

    var courses = Model.Courses ?? [];
    var totalCourses = courses.Count;
    var publishedCourses = courses.Count(x => x.IsPublished);
    var draftCourses = courses.Count(x => !x.IsPublished);
    var totalStudents = courses.Sum(x => x.StudentsCount);
    var totalLessons = courses.Sum(x => x.LessonsCount);
    var averagePrice = totalCourses == 0 ? 0 : courses.Average(x => x.Price);
    var successMessage = TempData["SuccessMessage"] as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - MvcAAp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        :root {
            --bg: #f4f7fb;
            --panel: #ffffff;
            --panel-soft: #f8fafc;
            --text: #111827;
            --muted: #64748b;
            --border: #dfe7f1;
            --line: #ecf1f7;
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --primary-soft: #e8f0ff;
            --teal: #0f766e;
            --teal-soft: #ccfbf1;
            --green: #15803d;
            --green-soft: #dcfce7;
            --amber: #b45309;
            --amber-soft: #fef3c7;
            --red: #dc2626;
            --red-soft: #fee2e2;
            --slate: #334155;
            --shadow: 0 16px 38px rgba(15, 23, 42, .08);
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            min-height: 100%;
            margin: 0;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: "Inter", "Segoe UI", system-ui, sans-serif;
            overflow-x: hidden;
        }

        button,
        input,
        select,
        textarea {
            font: inherit;
        }

        .app-shell {
            display: grid;
            grid-template-columns: 248px minmax(0, 1fr);
            min-height: 100vh;
        }

        .sidebar {
            position: sticky;
            top: 0;
            height: 100vh;
            padding: 20px 14px;
            background: #eef4fb;
            border-right: 1px solid var(--border);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 6px 8px 22px;
        }

        .brand-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            background: var(--slate);
            color: #ffffff;
            display: grid;
            place-items: center;
            font-size: 19px;
        }

        .brand-name {
            margin: 0;
            font-size: 20px;
            font-weight: 800;
            line-height: 1;
        }

        .brand-subtitle {
            margin-top: 4px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
        }

        .nav-title {
            margin: 10px 10px 8px;
            color: var(--muted);
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .side-nav {
            display: grid;
            gap: 6px;
        }

        .side-link {
            height: 42px;
            padding: 0 12px;
            border-radius: 8px;
            color: #40536b;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
        }

        .side-link i {
            width: 18px;
            color: #708199;
            font-size: 16px;
        }

        .side-link:hover,
        .side-link.active {
            background: #ffffff;
            color: var(--primary);
            box-shadow: 0 8px 18px rgba(15, 23, 42, .06);
        }

        .side-link:hover i,
        .side-link.active i {
            color: var(--primary);
        }

        .sidebar-note {
            margin-top: 22px;
            padding: 14px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: rgba(255, 255, 255, .72);
        }

        .sidebar-note strong {
            display: block;
            margin-bottom: 4px;
            color: var(--text);
            font-size: 13px;
        }

        .sidebar-note span {
            color: var(--muted);
            display: block;
            font-size: 12px;
            line-height: 1.5;
        }

        .main {
            min-width: 0;
            padding: 22px;
        }

        .topbar {
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .page-title {
            margin: 0;
            color: var(--text);
            font-size: 26px;
            font-weight: 800;
            line-height: 1.15;
        }

        .page-subtitle {
            margin: 5px 0 0;
            color: var(--muted);
            font-size: 14px;
        }

        .top-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .utility-pill,
        .profile-pill {
            min-height: 40px;
            padding: 0 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--panel);
            color: var(--slate);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 700;
        }

        .profile-mark {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: var(--slate);
            color: #ffffff;
            display: grid;
            place-items: center;
            font-size: 12px;
            font-weight: 800;
        }

        .btn-primary-ui {
            min-height: 40px;
            padding: 0 14px;
            border: 0;
            border-radius: 8px;
            background: var(--primary);
            color: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 800;
            text-decoration: none;
            box-shadow: 0 12px 24px rgba(37, 99, 235, .22);
        }

        .btn-primary-ui:hover {
            background: var(--primary-dark);
            color: #ffffff;
        }

        .btn-secondary-ui {
            min-height: 40px;
            padding: 0 14px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: #ffffff;
            color: var(--slate);
            font-size: 13px;
            font-weight: 800;
        }

        .message {
            margin-bottom: 16px;
            padding: 12px 14px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 9px;
            font-size: 14px;
            font-weight: 700;
        }

        .message.success {
            background: var(--green-soft);
            color: var(--green);
        }

        .message.error {
            background: var(--red-soft);
            color: #991b1b;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
            margin-bottom: 18px;
        }

        .stat-card {
            min-height: 126px;
            padding: 16px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--panel);
            box-shadow: 0 10px 26px rgba(15, 23, 42, .05);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .stat-card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 10px;
        }

        .stat-label {
            margin: 0;
            color: var(--muted);
            font-size: 12px;
            font-weight: 700;
        }

        .stat-title {
            margin: 5px 0 0;
            color: var(--text);
            font-size: 15px;
            font-weight: 800;
        }

        .stat-icon {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            background: var(--primary-soft);
            color: var(--primary);
            display: grid;
            place-items: center;
            flex: 0 0 auto;
        }

        .stat-icon.green {
            background: var(--green-soft);
            color: var(--green);
        }

        .stat-icon.teal {
            background: var(--teal-soft);
            color: var(--teal);
        }

        .stat-icon.amber {
            background: var(--amber-soft);
            color: var(--amber);
        }

        .stat-value {
            color: var(--text);
            font-size: 28px;
            font-weight: 800;
            line-height: 1;
        }

        .stat-meta {
            margin-top: 6px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
        }

        .content-panel {
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--panel);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .panel-toolbar {
            padding: 16px;
            border-bottom: 1px solid var(--line);
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
        }

        .panel-title {
            margin: 0;
            color: var(--text);
            font-size: 18px;
            font-weight: 800;
        }

        .panel-subtitle {
            margin: 4px 0 0;
            color: var(--muted);
            font-size: 13px;
        }

        .table-wrap {
            width: 100%;
            overflow-x: hidden;
        }

        .courses-table {
            width: 100%;
            margin: 0;
            table-layout: fixed;
        }

        .courses-table th {
            padding: 13px 14px;
            border-bottom: 1px solid var(--line);
            background: #f2f6fb;
            color: #475569;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            vertical-align: middle;
        }

        .courses-table td {
            padding: 14px;
            border-bottom: 1px solid var(--line);
            color: var(--text);
            font-size: 13px;
            vertical-align: middle;
        }

        .courses-table tbody tr:hover {
            background: #fbfdff;
        }

        .col-course {
            width: 32%;
        }

        .col-instructor {
            width: 15%;
        }

        .col-price {
            width: 10%;
        }

        .col-level {
            width: 12%;
        }

        .col-students {
            width: 10%;
        }

        .col-status {
            width: 12%;
        }

        .col-actions {
            width: 9%;
        }

        .course-cell {
            display: flex;
            align-items: center;
            gap: 11px;
            min-width: 0;
        }

        .course-avatar {
            width: 44px;
            height: 44px;
            border-radius: 8px;
            background: #334155;
            color: #ffffff;
            display: grid;
            place-items: center;
            flex: 0 0 auto;
            font-size: 16px;
            font-weight: 800;
        }

        .course-thumb {
            width: 44px;
            height: 44px;
            border-radius: 8px;
            object-fit: cover;
            flex: 0 0 auto;
        }

        .course-copy {
            min-width: 0;
        }

        .course-title {
            color: var(--text);
            font-size: 14px;
            font-weight: 800;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .course-description {
            margin-top: 4px;
            color: var(--muted);
            font-size: 12px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .muted-text {
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
        }

        .strong-text {
            color: var(--text);
            font-weight: 800;
        }

        .badge-ui {
            min-height: 28px;
            padding: 0 10px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .badge-beginner {
            background: var(--primary-soft);
            color: var(--primary);
        }

        .badge-intermediate {
            background: var(--amber-soft);
            color: var(--amber);
        }

        .badge-advanced {
            background: var(--red-soft);
            color: var(--red);
        }

        .badge-published {
            background: var(--green-soft);
            color: var(--green);
        }

        .badge-draft {
            background: #edf2f7;
            color: #475569;
        }

        .action-button {
            width: 36px;
            height: 36px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: #ffffff;
            color: #475569;
            display: inline-grid;
            place-items: center;
        }

        .action-button:hover,
        .action-button.show {
            background: var(--primary-soft);
            color: var(--primary);
        }

        .dropdown-menu {
            border: 1px solid var(--border);
            border-radius: 8px;
            box-shadow: 0 16px 34px rgba(15, 23, 42, .12);
        }

        .dropdown-item {
            min-height: 38px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            gap: 9px;
            font-size: 13px;
            font-weight: 700;
        }

        .dropdown-form {
            margin: 0;
        }

        .dropdown-form .dropdown-item {
            width: 100%;
            border: 0;
            background: transparent;
            text-align: left;
        }

        .dropdown-form .danger {
            color: #991b1b;
        }

        .empty-state {
            padding: 56px 18px;
            text-align: center;
            color: var(--muted);
        }

        .empty-icon {
            width: 54px;
            height: 54px;
            margin: 0 auto 12px;
            border-radius: 8px;
            background: var(--primary-soft);
            color: var(--primary);
            display: grid;
            place-items: center;
            font-size: 24px;
        }

        .empty-title {
            color: var(--text);
            font-size: 16px;
            font-weight: 800;
        }

        .modal-content {
            border: 1px solid var(--border);
            border-radius: 8px;
            box-shadow: 0 24px 64px rgba(15, 23, 42, .24);
        }

        .modal-header,
        .modal-footer {
            border-color: var(--line);
        }

        .modal-title {
            color: var(--text);
            font-size: 19px;
            font-weight: 800;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
        }

        .form-field.full {
            grid-column: 1 / -1;
        }

        .form-label {
            margin-bottom: 6px;
            color: var(--slate);
            font-size: 12px;
            font-weight: 800;
        }

        .form-control,
        .form-select {
            min-height: 44px;
            border-color: var(--border);
            border-radius: 8px;
            color: var(--text);
            font-weight: 600;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 .2rem rgba(37, 99, 235, .14);
        }

        textarea.form-control {
            min-height: 112px;
        }

        .field-validation-error {
            margin-top: 6px;
            color: var(--red);
            display: block;
            font-size: 12px;
            font-weight: 700;
        }

        .validation-summary-valid {
            display: none;
        }

        .validation-summary-errors {
            margin-bottom: 14px;
            padding: 12px 14px;
            border-radius: 8px;
            background: var(--red-soft);
            color: #991b1b;
            font-size: 13px;
            font-weight: 700;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }

        @@media (max-width: 1120px) {
            .stats-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .courses-table th:nth-child(2),
            .courses-table td:nth-child(2),
            .courses-table th:nth-child(5),
            .courses-table td:nth-child(5) {
                display: none;
            }

            .col-course {
                width: 42%;
            }
        }

        @@media (max-width: 820px) {
            .app-shell {
                grid-template-columns: 1fr;
            }

            .sidebar {
                position: static;
                height: auto;
                padding: 14px;
            }

            .sidebar-note {
                display: none;
            }

            .main {
                padding: 16px;
            }

            .topbar,
            .panel-toolbar {
                align-items: flex-start;
                flex-direction: column;
            }

            .top-actions {
                width: 100%;
                justify-content: flex-start;
            }
        }

        @@media (max-width: 680px) {
            .stats-grid,
            .form-grid {
                grid-template-columns: 1fr;
            }

            .table-wrap {
                overflow: visible;
            }

            .courses-table,
            .courses-table tbody,
            .courses-table tr,
            .courses-table td {
                display: block;
                width: 100%;
            }

            .courses-table thead,
            .courses-table colgroup {
                display: none;
            }

            .courses-table tr {
                padding: 12px;
                border-bottom: 1px solid var(--line);
            }

            .courses-table td {
                min-height: 40px;
                padding: 8px 0;
                border: 0;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 14px;
            }

            .courses-table td::before {
                content: attr(data-label);
                color: var(--muted);
                flex: 0 0 104px;
                font-size: 12px;
                font-weight: 800;
            }

            .courses-table td.course-main {
                display: block;
            }

            .courses-table td.course-main::before {
                display: none;
            }

            .course-title,
            .course-description {
                white-space: normal;
            }

            .page-title {
                font-size: 23px;
            }
        }
    </style>
</head>

<body>
<div class="app-shell">
    <aside class="sidebar">
        <div class="brand">
            <div class="brand-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div>
                <h1 class="brand-name">OnlineCourses</h1>
                <div class="brand-subtitle">MVC admin panel</div>
            </div>
        </div>

        <div class="nav-title">Workspace</div>
        <nav class="side-nav">
            <a asp-controller="Course" asp-action="Index" class="side-link active">
                <i class="bi bi-journal-bookmark-fill"></i>
                Courses
            </a>
            <a href="#" class="side-link">
                <i class="bi bi-play-btn-fill"></i>
                Lessons
            </a>
            <a href="#" class="side-link">
                <i class="bi bi-tags-fill"></i>
                Categories
            </a>
            <a href="#" class="side-link">
                <i class="bi bi-people-fill"></i>
                Students
            </a>
        </nav>

        <div class="sidebar-note">
            <strong>Clean Architecture</strong>
            <span>MVC talks to Application services and keeps validation inside the service layer.</span>
        </div>
    </aside>

    <main class="main">
        <header class="topbar">
            <div>
                <h2 class="page-title">Courses Dashboard</h2>
                <p class="page-subtitle">Create, publish, review and manage course catalog data.</p>
            </div>

            <div class="top-actions">
                <div class="utility-pill">
                    <i class="bi bi-calendar2-week"></i>
                    @DateTime.Now.ToString("dd MMM yyyy")
                </div>
                <div class="profile-pill">
                    <span class="profile-mark">AD</span>
                    Admin
                </div>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="message success" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                @successMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) && !Model.ShowModal)
        {
            <div class="message error" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @Model.ErrorMessage
            </div>
        }

        <section class="stats-grid" aria-label="Course statistics">
            <article class="stat-card">
                <div class="stat-card-header">
                    <div>
                        <p class="stat-label">Catalog</p>
                        <h3 class="stat-title">Total courses</h3>
                    </div>
                    <div class="stat-icon">
                        <i class="bi bi-collection-fill"></i>
                    </div>
                </div>
                <div>
                    <div class="stat-value">@totalCourses</div>
                    <div class="stat-meta">@totalLessons lessons in catalog</div>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-card-header">
                    <div>
                        <p class="stat-label">Live</p>
                        <h3 class="stat-title">Published</h3>
                    </div>
                    <div class="stat-icon green">
                        <i class="bi bi-check2-circle"></i>
                    </div>
                </div>
                <div>
                    <div class="stat-value">@publishedCourses</div>
                    <div class="stat-meta">@draftCourses drafts waiting</div>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-card-header">
                    <div>
                        <p class="stat-label">Students</p>
                        <h3 class="stat-title">Enrollments</h3>
                    </div>
                    <div class="stat-icon teal">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
                <div>
                    <div class="stat-value">@totalStudents</div>
                    <div class="stat-meta">Across all courses</div>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-card-header">
                    <div>
                        <p class="stat-label">Pricing</p>
                        <h3 class="stat-title">Average price</h3>
                    </div>
                    <div class="stat-icon amber">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                </div>
                <div>
                    <div class="stat-value">$@averagePrice.ToString("0.00")</div>
                    <div class="stat-meta">Based on current catalog</div>
                </div>
            </article>
        </section>

        <section class="content-panel">
            <div class="panel-toolbar">
                <div>
                    <h3 class="panel-title">Courses List</h3>
                    <p class="panel-subtitle">@totalCourses courses / @publishedCourses published / @totalStudents students</p>
                </div>
                <button type="button" class="btn-primary-ui" data-bs-toggle="modal" data-bs-target="#createCourseModal">
                    <i class="bi bi-plus-circle"></i>
                    Add Course
                </button>
            </div>

            <div class="table-wrap">
                <table class="courses-table">
                    <colgroup>
                        <col class="col-course" />
                        <col class="col-instructor" />
                        <col class="col-price" />
                        <col class="col-level" />
                        <col class="col-students" />
                        <col class="col-status" />
                        <col class="col-actions" />
                    </colgroup>
                    <thead>
                    <tr>
                        <th>Course</th>
                        <th>Instructor</th>
                        <th>Price</th>
                        <th>Level</th>
                        <th>Students</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (courses.Any())
                    {
                        foreach (var course in courses)
                        {
                            var firstLetter = string.IsNullOrWhiteSpace(course.Title)
                                ? "C"
                                : course.Title[..1].ToUpper();

                            var instructor = string.IsNullOrWhiteSpace(course.InstructorName)
                                ? "Default Admin"
                                : course.InstructorName;

                            var description = string.IsNullOrWhiteSpace(course.Description)
                                ? course.CategoryName
                                : course.Description;

                            var levelClass = course.Level switch
                            {
                                CourseLevel.Beginner => "badge-beginner",
                                CourseLevel.Intermediate => "badge-intermediate",
                                CourseLevel.Advanced => "badge-advanced",
                                _ => "badge-beginner"
                            };

                            <tr>
                                <td class="course-main" data-label="Course">
                                    <div class="course-cell">
                                        @if (!string.IsNullOrWhiteSpace(course.ThumbnailUrl))
                                        {
                                            <img src="@course.ThumbnailUrl" class="course-thumb" alt="@course.Title" />
                                        }
                                        else
                                        {
                                            <div class="course-avatar">@firstLetter</div>
                                        }

                                        <div class="course-copy">
                                            <div class="course-title">@course.Title</div>
                                            <div class="course-description">@description</div>
                                            <div class="muted-text mt-1">@course.CategoryName</div>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Instructor">
                                    <div class="strong-text">@instructor</div>
                                </td>
                                <td data-label="Price">
                                    <span class="strong-text">$@course.Price.ToString("0.00")</span>
                                </td>
                                <td data-label="Level">
                                    <span class="badge-ui @levelClass">@course.Level</span>
                                </td>
                                <td data-label="Students">
                                    <span class="badge-ui badge-draft">
                                        <i class="bi bi-people-fill"></i>
                                        @course.StudentsCount
                                    </span>
                                </td>
                                <td data-label="Status">
                                    @if (course.IsPublished)
                                    {
                                        <span class="badge-ui badge-published">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge-ui badge-draft">Draft</span>
                                    }
                                </td>
                                <td class="text-end" data-label="Actions">
                                    <div class="dropdown">
                                        <button class="action-button" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Course actions">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <div class="dropdown-menu dropdown-menu-end p-2">
                                            <button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#editCourseModal-@course.Id">
                                                <i class="bi bi-pencil-square"></i>
                                                Edit
                                            </button>
                                            <form asp-controller="Course" asp-action="Publish" asp-route-id="@course.Id" method="post" class="dropdown-form">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item">
                                                    <i class="bi @(course.IsPublished ? "bi-pause-circle" : "bi-check-circle")"></i>
                                                    @(course.IsPublished ? "Move to Draft" : "Publish")
                                                </button>
                                            </form>
                                            <form asp-controller="Course" asp-action="Delete" asp-route-id="@course.Id" method="post" class="dropdown-form" onsubmit="return confirm('Delete this course?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item danger">
                                                    <i class="bi bi-trash3"></i>
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="bi bi-folder-plus"></i>
                                    </div>
                                    <div class="empty-title">No courses yet</div>
                                    <div>Create the first course and it will appear here immediately.</div>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>

@foreach (var course in courses)
{
    <div class="modal fade" id="editCourseModal-@course.Id" tabindex="-1" aria-labelledby="editCourseModalLabel-@course.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <form asp-controller="Course" asp-action="Edit" asp-route-id="@course.Id" method="post">
                    @Html.AntiForgeryToken()

                    <div class="modal-header">
                        <div>
                            <h3 class="modal-title" id="editCourseModalLabel-@course.Id">Edit Course</h3>
                            <p class="mb-0 text-muted small fw-semibold">Update course information and save it back to the database.</p>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <div class="form-grid">
                            <div class="form-field full">
                                <label for="edit-title-@course.Id" class="form-label">Title</label>
                                <input id="edit-title-@course.Id" name="Title" value="@course.Title" class="form-control" />
                            </div>

                            <div class="form-field full">
                                <label for="edit-description-@course.Id" class="form-label">Description</label>
                                <textarea id="edit-description-@course.Id" name="Description" class="form-control">@course.Description</textarea>
                            </div>

                            <div class="form-field">
                                <label for="edit-price-@course.Id" class="form-label">Price</label>
                                <input id="edit-price-@course.Id" name="Price" value="@course.Price" class="form-control" type="number" min="0" step="0.01" />
                            </div>

                            <div class="form-field">
                                <label for="edit-level-@course.Id" class="form-label">Level</label>
                                <select id="edit-level-@course.Id" name="Level" class="form-select">
                                    @foreach (var level in Enum.GetValues<CourseLevel>())
                                    {
                                        <option value="@level" selected="@(course.Level == level)">@level</option>
                                    }
                                </select>
                            </div>

                            <div class="form-field full">
                                <label for="edit-category-@course.Id" class="form-label">Category</label>
                                <select id="edit-category-@course.Id" name="CategoryId" class="form-select">
                                    @foreach (var category in Model.Categories)
                                    {
                                        <option value="@category.Value" selected="@(course.CategoryId.ToString() == category.Value)">@category.Text</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-secondary-ui" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn-primary-ui">
                            <i class="bi bi-check-circle-fill"></i>
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="createCourseModal" tabindex="-1" aria-labelledby="createCourseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-controller="Course" asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <div>
                        <h3 class="modal-title" id="createCourseModalLabel">Add Course</h3>
                        <p class="mb-0 text-muted small fw-semibold">Add a course with a valid category from the database.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="message error" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            @Model.ErrorMessage
                        </div>
                    }

                    <div asp-validation-summary="ModelOnly"></div>

                    <div class="form-grid">
                        <div class="form-field full">
                            <label asp-for="Dto.Title" class="form-label">Title</label>
                            <input asp-for="Dto.Title" class="form-control" placeholder="ASP.NET Core Web API Masterclass" />
                            <span asp-validation-for="Dto.Title"></span>
                        </div>

                        <div class="form-field full">
                            <label asp-for="Dto.Description" class="form-label">Description</label>
                            <textarea asp-for="Dto.Description" class="form-control" placeholder="Short course description"></textarea>
                            <span asp-validation-for="Dto.Description"></span>
                        </div>

                        <div class="form-field">
                            <label asp-for="Dto.Price" class="form-label">Price</label>
                            <input asp-for="Dto.Price" class="form-control" type="number" min="0" step="0.01" />
                            <span asp-validation-for="Dto.Price"></span>
                        </div>

                        <div class="form-field">
                            <label asp-for="Dto.Level" class="form-label">Level</label>
                            <select asp-for="Dto.Level" class="form-select" asp-items="Html.GetEnumSelectList<CourseLevel>()"></select>
                            <span asp-validation-for="Dto.Level"></span>
                        </div>

                        <div class="form-field full">
                            <label asp-for="Dto.CategoryId" class="form-label">Category</label>
                            <select asp-for="Dto.CategoryId" class="form-select" asp-items="Model.Categories">
                                <option value="">Choose category</option>
                            </select>
                            <span asp-validation-for="Dto.CategoryId"></span>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-secondary-ui" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-primary-ui">
                        <i class="bi bi-check-circle-fill"></i>
                        Save Course
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@if (Model.ShowModal)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const modalElement = document.getElementById("createCourseModal");
            if (modalElement) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }
        });
    </script>
}
</body>
</html>
